              "file_name": "examples/demo_notes.md",
              "page": null,
              "slide": null,
              "paragraph": 29,
              "priority": "high"
            }
          ]
        },
        {
          "id": "82b4ac5d8465",
          "name": "2.2 作用域",
          "content": "LEGB 规则：Local → Enclosing → Global → Built-in\n注意：在函数内修改全局变量需要使用 global 关键字。",
          "level": 3,
          "importance": "low",
